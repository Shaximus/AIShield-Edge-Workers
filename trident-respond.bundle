async function writeAuditLog(env, entry) {
  const record = {
    id: entry.id ?? crypto.randomUUID(),
    timestamp: entry.timestamp ?? Date.now(),
    worker: entry.worker,
    severity: entry.severity,
    category: entry.category,
    message: entry.message,
    sourceIp: entry.sourceIp,
    threatId: entry.threatId,
    metadata: entry.metadata
  };
  try {
    await d1Query(
      env.AURIS_LOGS,
      `INSERT INTO error_log (id, timestamp, worker, severity, category, message, source_ip, threat_id, metadata)
       VALUES (?1, ?2, ?3, ?4, ?5, ?6, ?7, ?8, ?9)`,
      [
        record.id,
        record.timestamp,
        record.worker,
        record.severity,
        record.category,
        record.message,
        record.sourceIp ?? null,
        record.threatId ?? null,
        record.metadata ? JSON.stringify(record.metadata) : null
      ]
    );
  } catch (err) {
    try {
      await env.SESSION_META.put(
        `audit-fallback:${record.id}`,
        JSON.stringify(record),
        { expirationTtl: 86400 }
      );
    } catch (kvErr) {
      console.error("[TRIDENT-AUDIT] Both D1 and KV fallback failed:", kvErr);
    }
    throw err;
  }
}
