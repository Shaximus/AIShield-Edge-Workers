var WORKER_NAME = "trident-respond";
async function sendSmsAlert(env, threat) {
  const gatewayUrl = env.SMS_GATEWAY_URL;
  if (!gatewayUrl) {
    await logEvent(env, {
      worker: WORKER_NAME,
      severity: "MEDIUM",
      category: "sms_not_configured",
      message: `SMS gateway not configured; skipping alert for threat ${threat.id}`,
      sourceIp: threat.sourceIp,
      threatId: threat.id
    });
    return;
  }
  const payload = {
    message: `[TRIDENT] CRITICAL: ${threat.category} from ${threat.sourceIp} \u2014 Threat ID: ${threat.id}`,
    priority: "high"
  };
  const headers = {
    "Content-Type": "application/json"
  };
  if (env.SMS_GATEWAY_TOKEN) {
    headers["Authorization"] = `Bearer ${env.SMS_GATEWAY_TOKEN}`;
  }
  let response;
  try {
    response = await fetch(gatewayUrl, {
      method: "POST",
      headers,
      body: JSON.stringify(payload)
    });
  } catch (err) {
    await logEvent(env, {
      worker: WORKER_NAME,
      severity: "HIGH",
      category: "sms_network_error",
      message: `SMS gateway network error for threat ${threat.id}: ${err.message}`,
      sourceIp: threat.sourceIp,
      threatId: threat.id
    });
    throw new SmsAlertError(`Network error sending SMS: ${err.message}`, gatewayUrl, err);
  }
  if (!response.ok) {
    const body = await response.text().catch(() => "[unreadable]");
    await logEvent(env, {
      worker: WORKER_NAME,
      severity: "HIGH",
      category: "sms_gateway_error",
      message: `SMS gateway returned ${response.status} for threat ${threat.id}: ${body}`,
      sourceIp: threat.sourceIp,
      threatId: threat.id
    });
    throw new SmsAlertError(
      `SMS gateway returned HTTP ${response.status}`,
      gatewayUrl,
      { status: response.status, body }
    );
  }
  await logEvent(env, {
    worker: WORKER_NAME,
    severity: "INFO",
    category: "sms_sent",
    message: `SMS alert sent successfully for threat ${threat.id}`,
    sourceIp: threat.sourceIp,
    threatId: threat.id
  });
}
__name(sendSmsAlert, "sendSmsAlert");
var SmsAlertError = class extends Error {
  constructor(message, gatewayUrl, cause) {
    super(message);
    this.gatewayUrl = gatewayUrl;
    this.cause = cause;
    this.name = "SmsAlertError";
  }
};
