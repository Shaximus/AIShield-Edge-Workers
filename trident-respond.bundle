async function executeResponseLevel(env, threat, level, circuitState) {
  await logEvent(env, {
    worker: WORKER_NAME5,
    severity: "INFO",
    category: "response_execute_start",
    message: `Executing response level ${level} (${responseLevelName(level)}) for threat ${threat.id}`,
    sourceIp: threat.sourceIp,
    threatId: threat.id,
    metadata: {
      level,
      levelName: responseLevelName(level),
      confidence: threat.confidence,
      severity: threat.severity,
      circuitState: circuitState.state
    }
  });
  let result = {};
  switch (level) {
    case 0:
      await executeLevel0(env, threat, level);
      break;
    case 1:
      await executeLevel1(env, threat, level);
      break;
    case 2:
      await executeLevel2(env, threat, level);
      break;
    case 3:
      await executeLevel3(env, threat, level, circuitState);
      break;
    case 4:
      result = await executeLevel4(env, threat, level, circuitState);
      break;
    default:
      await logEvent(env, {
        worker: WORKER_NAME5,
        severity: "CRITICAL",
        category: "response_invalid_level",
        message: `Invalid response level ${level} for threat ${threat.id}`,
        sourceIp: threat.sourceIp,
        threatId: threat.id
      });
  }
  await logEvent(env, {
    worker: WORKER_NAME5,
    severity: "INFO",
    category: "response_execute_complete",
    message: `Response level ${level} complete for threat ${threat.id}`,
    sourceIp: threat.sourceIp,
    threatId: threat.id,
    metadata: {
      level,
      levelName: responseLevelName(level),
      hasRotation: !!result.rotationEvent
    }
  });
  return { level, rotationEvent: result.rotationEvent };
}
