async function recordBlockResult(env, wasFalsePositive, threatId) {
  const state = await readCircuitState(env);
  state.blocksLastHour += 1;
  if (wasFalsePositive) {
    state.falsePositives += 1;
  }
  state.lastChecked = Date.now();
  await logCircuitEvent(
    env,
    wasFalsePositive ? "false_positive_recorded" : "true_positive_recorded",
    wasFalsePositive ? `False positive recorded for threat ${threatId} (${state.falsePositives}/${state.blocksLastHour} total)` : `True positive recorded for threat ${threatId} (${state.blocksLastHour} blocks, ${state.falsePositives} FP)`,
    { threatId, wasFalsePositive, blocks: state.blocksLastHour, fp: state.falsePositives }
  );
  await writeCircuitState(env, state);
  if (state.state === "HALF_OPEN") {
    if (state.halfOpenTestId === threatId) {
      if (wasFalsePositive) {
        await logCircuitEvent(
          env,
          "half_open_failed",
          `HALF_OPEN test block was false positive \u2014 re-opening circuit`,
          { threatId }
        );
        await openCircuit(env, state);
      } else {
        await logCircuitEvent(
          env,
          "half_open_passed",
          `HALF_OPEN test block was true positive \u2014 closing circuit`,
          { threatId }
        );
        await closeCircuit(env, state);
      }
    }
  }
}
