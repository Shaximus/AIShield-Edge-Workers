async function d1Query(db, sql, params) {
  try {
    const stmt = db.prepare(sql).bind(...params);
    return await stmt.all();
  } catch (err) {
    console.error("[TRIDENT-DB] D1 query failed:", err);
    throw new D1QueryError(`D1 query failed: ${err.message}`, sql, params, err);
  }
}
