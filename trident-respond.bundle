// ../trident-shared/src/utils.ts
function ipToLong(ip) {
  const parts = ip.split(".");
  if (parts.length !== 4)
    return null;
  let num = 0;
  for (let i = 0; i < 4; i++) {
    const octet = parseInt(parts[i], 10);
    if (Number.isNaN(octet) || octet < 0 || octet > 255)
      return null;
    num = num << 8 | octet;
  }
  return num >>> 0;
}
__name(ipToLong, "ipToLong");
function isIpInCidr(ip, cidr) {
  try {
    const ipLong = ipToLong(ip);
    if (ipLong === null)
      return false;
    const [network, prefixStr] = cidr.split("/");
    if (!network || !prefixStr)
      return false;
    const prefix = parseInt(prefixStr, 10);
    if (Number.isNaN(prefix) || prefix < 0 || prefix > 32)
      return false;
    const netLong = ipToLong(network);
    if (netLong === null)
      return false;
    const mask = prefix === 0 ? 0 : ~0 << 32 - prefix >>> 0;
    return (ipLong & mask) === (netLong & mask);
  } catch (err) {
    console.error(`[TRIDENT-UTILS] isIpInCidr failed for ${ip} / ${cidr}:`, err.message);
    return false;
  }
}
__name(isIpInCidr, "isIpInCidr");
function isIpWhitelisted(ip, ranges) {
  for (const range of ranges) {
    if (range.includes("/")) {
      if (isIpInCidr(ip, range))
        return true;
    } else if (ip === range) {
      return true;
    }
  }
  return false;
}
__name(isIpWhitelisted, "isIpWhitelisted");

