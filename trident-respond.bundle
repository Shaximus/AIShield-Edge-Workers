          { fpRate, blocks: state.blocksLastHour, falsePositives: state.falsePositives }
        );
        return openCircuit(env, state);
      }
    }
  }
  if (now - state.lastChecked > BLOCKS_HOUR_WINDOW_MS) {
    state.blocksLastHour = 0;
    state.falsePositives = 0;
    state.lastChecked = now;
    await writeCircuitState(env, state);
    await logCircuitEvent(
