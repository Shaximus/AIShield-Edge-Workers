            status: resp.status,
            headers: { ...corsHeaders, "Content-Type": "application/json" }
          });
        }
        return new Response(JSON.stringify({
          success: true,
          tweet_id: data.data?.id,
          text: data.data?.text
        }), {
          headers: { ...corsHeaders, "Content-Type": "application/json" }
        });
      } catch (e) {
        return new Response(JSON.stringify({ error: e.message }), {
          status: 500,
          headers: { ...corsHeaders, "Content-Type": "application/json" }
        });
      }
    }
    if (url.pathname === "/thread" && request.method === "POST") {
      try {
        const body = await request.json();
        const tweets = body.tweets;
        if (!tweets || !Array.isArray(tweets) || tweets.length === 0) {
          return new Response(JSON.stringify({ error: "Array of tweet texts required" }), {
            status: 400,
            headers: { ...corsHeaders, "Content-Type": "application/json" }
          });
        }
        const results = [];
        let lastTweetId = null;
        for (const tweetText of tweets) {
          const tweetBody = { text: tweetText };
          if (lastTweetId) {
            tweetBody.reply = { in_reply_to_tweet_id: lastTweetId };
          }
          const resp = await fetch("https://api.twitter.com/2/tweets", {
            method: "POST",
            headers: {
              "Authorization": `Bearer ${env.TWITTER_BEARER_TOKEN}`,
              "Content-Type": "application/json"
            },
            body: JSON.stringify(tweetBody)
