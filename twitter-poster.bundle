          if (!resp.ok) {
            results.push({ error: data, status: resp.status });
            break;
          }
          lastTweetId = data.data?.id;
          results.push({
            success: true,
            tweet_id: data.data?.id,
            text: data.data?.text
          });
        }
        return new Response(JSON.stringify({
          posted: results.length,
          tweets: results
        }), {
          headers: { ...corsHeaders, "Content-Type": "application/json" }
        });
