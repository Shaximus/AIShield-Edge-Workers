    }
    return new Response(JSON.stringify({
      endpoints: [
        "GET /status \u2014 Check API quota",
        'POST /tweet \u2014 Post single tweet (body: {text: "..."})',
        'POST /thread \u2014 Post thread (body: {tweets: ["...", "..."]})'
