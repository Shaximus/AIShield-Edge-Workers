async function fetchRecentAuditTrail(db) {
  const since = Math.floor(Date.now() / 1e3) - 60;
  try {
    const stmt = db.prepare(
      `SELECT id, timestamp, module, action, target, source_ip, source_worker, query, metadata, severity
       FROM audit_trail
       WHERE timestamp >= ?
       ORDER BY timestamp DESC`
    );
    const result = await stmt.bind(since).all();
    const rows = result.results ?? [];
    return rows.map((r) => ({
      id: String(r.id ?? ""),
      timestamp: Number(r.timestamp ?? 0),
      module: r.module ? String(r.module) : null,
      action: r.action ? String(r.action) : null,
      target: r.target ? String(r.target) : null,
      source_ip: r.source_ip ? String(r.source_ip) : null,
      source_worker: r.source_worker ? String(r.source_worker) : null,
      query: r.query ? String(r.query) : null,
      metadata: r.metadata ? String(r.metadata) : null,
      severity: r.severity ? String(r.severity) : null
    }));
  } catch (err) {
    await logError4(db, "fetchRecentAuditTrail", "ERROR", "D1QueryError", err instanceof Error ? err.message : String(err), JSON.stringify({ since }));
    throw err;
  }
}
