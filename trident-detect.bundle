      const isRoutes = /MOE_ROUTES/i.test(event.target);
      const isAllowedWorker = !!event.source_worker && event.source_worker === "moe-precognition-router";
      return isWrite && isRoutes && !isAllowedWorker;
    }
  },
  {
    category: "moe_embedding_poisoning",
    severity: "MEDIUM",
    message: "Write to MOE_EMBEDDINGS outside scheduled evaluation window",
    check: (event) => {
      if (!event.action || !event.target || !event.timestamp)
        return false;
      const isWrite = /^(PUT|DELETE|WRITE|UPDATE)$/i.test(event.action);
      const isEmbeddings = /MOE_EMBEDDINGS/i.test(event.target);
      const hour = new Date(event.timestamp * 1e3).getUTCHours();
      const inWindow = hour >= 2 && hour <= 4;
      return isWrite && isEmbeddings && !inWindow;
    }
  },
  {
    category: "moe_routes_manipulation",
    severity: "HIGH",
    message: "Delete operation on MOE_HOT namespace",
    check: (event) => {
      if (!event.action || !event.target)
        return false;
      const isDelete = /^(DELETE|DEL|REMOVE)$/i.test(event.action);
      const isMoeHot = /MOE_HOT/i.test(event.target);
      return isDelete && isMoeHot;
    }
  },
  {
    category: "quality_gate_tampering",
    severity: "HIGH",
    message: "Update to moe-metrics.quality_gates outside scheduled window",
    check: (event) => {
      if (!event.action || !event.target || !event.timestamp)
        return false;
      const isUpdate = /^(PUT|DELETE|WRITE|UPDATE)$/i.test(event.action);
      const isQualityGates = /moe-metrics.*quality_gates|quality_gates/i.test(event.target);
      const hour = new Date(event.timestamp * 1e3).getUTCHours();
      const inWindow = hour >= 2 && hour <= 4;
      return isUpdate && isQualityGates && !inWindow;
    }
  }
