async function generateZipBundle(jsonReport, htmlReport, topThreats) {
  const zip = new ZipBuilder();
  zip.addFile("follower_analysis.json", jsonReport);
  zip.addFile("bot_summary.html", htmlReport);
  for (let i = 0; i < Math.min(20, topThreats.length); i++) {
    const bot = topThreats[i];
    const username = String(bot.username ?? "unknown");
    zip.addFile(
      `evidence/${String(i + 1).padStart(2, "0")}_${username}.json`,
      JSON.stringify(bot, null, 2)
    );
  }
  return zip.build();
}
