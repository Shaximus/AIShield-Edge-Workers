function generateHTMLReport(report) {
  const s = report.summary;
  const scan = report.scan_details;
  const generatedAt = new Date(report.generated_at).toLocaleDateString("en-US", {
    year: "numeric",
    month: "long",
    day: "numeric",
    hour: "2-digit",
    minute: "2-digit"
  });
  const highH = Math.min(100, s.threat_levels.high * 5);
  const medH = Math.min(100, s.threat_levels.medium * 5);
  const lowH = Math.min(100, s.threat_levels.low * 5);
  let threatRows = "";
  for (let i = 0; i < Math.min(20, report.top_threats.length); i++) {
    const bot = report.top_threats[i];
    const score = Number(bot.bot_score ?? 0);
    const cls = score >= 7 ? "high" : score >= 4 ? "medium" : "low";
    const typeStr = String(bot.bot_type ?? "UNKNOWN");
    threatRows += `
          <tr>
            <td>${i + 1}</td>
            <td class="td-user">
              <span class="user-icon">@${String(bot.username ?? "unknown").charAt(0)}</span>
              @${String(bot.username ?? "unknown")}
            </td>
            <td><span class="score-badge score-${cls}">${score.toFixed(2)}</span></td>
            <td><span class="type-tag type-${typeStr.toLowerCase().replace(/[^a-z0-9]/g, "-")}">${typeStr}</span></td>
            <td class="mono">${Number(bot.followers_count ?? 0).toLocaleString()}</td>
            <td class="mono">${Number(bot.following_count ?? 0).toLocaleString()}</td>
          </tr>`;
  }
  let typeBars = "";
  const maxTypeCount = Math.max(1, ...Object.values(report.bot_types));
  for (const [type, count] of Object.entries(report.bot_types)) {
    const pct = (count / s.total_bots * 100).toFixed(1);
    const barW = (count / maxTypeCount * 100).toFixed(1);
    typeBars += `
          <div class="type-row">
            <span class="type-label">${type}</span>
            <div class="type-track">
              <div class="type-fill" style="width:${barW}%">${count}</div>
            </div>
            <span class="type-pct mono">${pct}%</span>
          </div>`;
  }
  let recs = "";
  const botRate = scan.bot_rate ?? 0;
  if (botRate > 30) {
    recs += `<li class="rec-high"><span class="rec-icon">\u{1F6A8}</span><div><strong>Critical Bot Infiltration:</strong> Over 30% of followers are bot accounts. Immediate action recommended \u2014 audit your follower list and consider removing suspicious accounts. Your engagement metrics may be severely skewed.</div></li>`;
  } else if (botRate > 15) {
    recs += `<li class="rec-medium"><span class="rec-icon">\u26A0\uFE0F</span><div><strong>Moderate Bot Presence:</strong> 15\u201330% of followers are bots. Monitor engagement patterns and audit recently followed accounts. Consider periodic scans.</div></li>`;
  } else {
    recs += `<li class="rec-low"><span class="rec-icon">\u2705</span><div><strong>Low Bot Presence:</strong> Under 15% bot followers \u2014 your audience health is good. Continue monitoring with periodic scans.</div></li>`;
  }
  if (s.threat_levels.high > 10) {
    recs += `<li class="rec-high"><span class="rec-icon">\u{1F6A8}</span><div><strong>High-Threat Network:</strong> ${s.threat_levels.high} high-threat bots detected with combined reach of ${s.total_reach.toLocaleString()} followers. These accounts may be coordinating in a botnet.</div></li>`;
  }
  if (s.total_reach > 1e5) {
    recs += `<li class="rec-medium"><span class="rec-icon">\u26A0\uFE0F</span><div><strong>Bot Network Reach:</strong> Detected bot accounts have a combined follower reach of ${s.total_reach.toLocaleString()}. This amplifies their potential for disinformation.</div></li>`;
  }
  if (botRate > 50) {
    recs += `<li class="rec-high"><span class="rec-icon">\u{1F6A8}</span><div><strong>Platform Risk:</strong> Bot rate exceeds 50%. Your account may be flagged by platform algorithms. Consider a full audit and cleanup.</div></li>`;
  }
  return `<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Vigilante Report \u2014 @${report.customer}</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=DM+Sans:ital,opsz,wght@0,9..40,300;0,9..40,400;0,9..40,500;0,9..40,600;0,9..40,700;1,9..40,400&family=JetBrains+Mono:wght@400;500;600;700&display=swap" rel="stylesheet">
  <style>
    :root {
      --bg-deep: #020617;
      --bg-surface: #0f172a;
      --bg-card: #1e293b;
      --bg-card-hover: #26334d;
      --text-primary: #f1f5f9;
      --text-secondary: #94a3b8;
      --text-muted: #64748b;
      --accent: #06b6d4;
      --accent-light: #22d3ee;
      --accent-dark: #0891b2;
      --accent-glow: rgba(6, 182, 212, 0.15);
      --success: #10b981;
      --warning: #f59e0b;
      --danger: #ef4444;
      --border: rgba(148, 163, 184, 0.1);
      --radius-sm: 8px;
      --radius-lg: 12px;
    }
    *, *::before, *::after { margin: 0; padding: 0; box-sizing: border-box; }
    body {
      font-family: 'DM Sans', -apple-system, BlinkMacSystemFont, sans-serif;
      background: var(--bg-deep);
      color: var(--text-primary);
      line-height: 1.6;
      min-height: 100vh;
    }
    .container { max-width: 1200px; margin: 0 auto; padding: 0 24px; }
    /* Header */
    .header {
      background: linear-gradient(135deg, var(--bg-deep) 0%, var(--bg-surface) 50%, rgba(6,182,212,0.05) 100%);
      border-bottom: 1px solid var(--border);
      padding: 48px 0 40px;
      position: relative;
      overflow: hidden;
    }
    .header::before {
      content: '';
      position: absolute;
      top: -100px; right: -100px;
      width: 400px; height: 400px;
      background: radial-gradient(circle, var(--accent-glow) 0%, transparent 70%);
      pointer-events: none;
    }
    .header-badge {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      padding: 6px 16px;
      border-radius: 100px;
      background: rgba(6, 182, 212, 0.1);
      border: 1px solid rgba(6, 182, 212, 0.2);
      color: var(--accent);
      font-size: 0.8rem;
      font-weight: 600;
      letter-spacing: 0.5px;
      text-transform: uppercase;
      margin-bottom: 20px;
    }
    .header-badge .dot {
      width: 8px; height: 8px;
      border-radius: 50%;
      background: var(--accent);
      animation: pulse-dot 2s ease-in-out infinite;
    }
    @keyframes pulse-dot {
      0%, 100% { opacity: 1; box-shadow: 0 0 0 0 rgba(6,182,212,0.4); }
      50% { opacity: 0.8; box-shadow: 0 0 0 6px rgba(6,182,212,0); }
    }
    .header h1 {
      font-size: 2.25rem;
      font-weight: 700;
      letter-spacing: -0.02em;
      margin-bottom: 8px;
    }
    .header .target {
      font-family: 'JetBrains Mono', monospace;
      font-size: 1.1rem;
      color: var(--accent-light);
      font-weight: 600;
    }
    .header .date {
      font-size: 0.875rem;
      color: var(--text-secondary);
      margin-top: 12px;
    }
    .header-grid {
      display: grid;
      grid-template-columns: 1fr auto;
      align-items: start;
      gap: 40px;
    }
    .header-score {
      text-align: center;
      padding: 24px 32px;
      background: var(--bg-card);
      border-radius: var(--radius-lg);
      border: 1px solid var(--border);
      min-width: 180px;
    }
    .header-score .score-label {
      font-size: 0.75rem;
      text-transform: uppercase;
      letter-spacing: 1px;
      color: var(--text-muted);
      margin-bottom: 8px;
    }
    .header-score .score-value {
      font-family: 'JetBrains Mono', monospace;
      font-size: 3rem;
      font-weight: 700;
      line-height: 1;
    }
    .header-score .score-value.danger { color: var(--danger); }
    .header-score .score-value.warning { color: var(--warning); }
    .header-score .score-value.success { color: var(--success); }
    .header-score .score-desc {
      font-size: 0.8rem;
      color: var(--text-secondary);
      margin-top: 8px;
    }

    /* Section */
    .section { padding: 40px 0; border-bottom: 1px solid var(--border); }
    .section:last-child { border-bottom: none; }
    .section-title {
      font-size: 1.25rem;
      font-weight: 600;
      margin-bottom: 24px;
      display: flex;
      align-items: center;
      gap: 12px;
    }
    .section-title .icon {
      width: 36px; height: 36px;
      border-radius: var(--radius-sm);
      background: var(--accent-glow);
      display: inline-flex;
      align-items: center;
      justify-content: center;
      font-size: 1rem;
    }

    /* Stats Grid */
    .stats-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
      gap: 16px;
    }
    .stat-card {
      background: var(--bg-card);
      border-radius: var(--radius-lg);
      padding: 24px;
      border: 1px solid var(--border);
      transition: border-color 0.2s, transform 0.2s;
    }
    .stat-card:hover {
      border-color: rgba(6, 182, 212, 0.2);
      transform: translateY(-2px);
    }
    .stat-card .stat-label {
      font-size: 0.75rem;
      text-transform: uppercase;
      letter-spacing: 1.2px;
      color: var(--text-muted);
      margin-bottom: 8px;
    }
    .stat-card .stat-value {
      font-family: 'JetBrains Mono', monospace;
      font-size: 1.75rem;
      font-weight: 700;
      color: var(--text-primary);
    }
    .stat-card .stat-value.accent { color: var(--accent-light); }
    .stat-card .stat-value.danger { color: var(--danger); }
    .stat-card .stat-value.warning { color: var(--warning); }
    .stat-card .stat-value.success { color: var(--success); }
    .stat-card .stat-bar {
      height: 4px;
      border-radius: 2px;
      background: var(--bg-deep);
      margin-top: 12px;
      overflow: hidden;
    }
    .stat-card .stat-bar-fill {
      height: 100%;
      border-radius: 2px;
      background: var(--accent);
      transition: width 1s ease-out;
    }

    /* Category Grid */
    .cat-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
      gap: 16px;
      margin-top: 16px;
    }
    .cat-card {
      background: var(--bg-card);
      border-radius: var(--radius-lg);
      padding: 20px;
      border: 1px solid var(--border);
      text-align: center;
      position: relative;
      overflow: hidden;
    }
    .cat-card::before {
      content: '';
      position: absolute;
      top: 0; left: 0; right: 0;
      height: 3px;
    }
    .cat-card.danger::before { background: var(--danger); }
    .cat-card.warning::before { background: var(--warning); }
    .cat-card.success::before { background: var(--success); }
    .cat-card.accent::before { background: var(--accent); }
    .cat-card .cat-count {
      font-family: 'JetBrains Mono', monospace;
      font-size: 1.5rem;
      font-weight: 700;
    }
    .cat-card .cat-label {
      font-size: 0.8rem;
      color: var(--text-secondary);
      margin-top: 4px;
    }
    .cat-card .cat-pct {
      font-family: 'JetBrains Mono', monospace;
      font-size: 0.75rem;
      color: var(--text-muted);
      margin-top: 4px;
    }

    /* Threat Bars */
    .threat-bars-wrap {
      display: flex;
      gap: 16px;
      margin-top: 16px;
    }
    .threat-bar-card {
      flex: 1;
      background: var(--bg-card);
      border-radius: var(--radius-lg);
      padding: 20px;
      border: 1px solid var(--border);
      text-align: center;
    }
    .threat-bar-track {
      height: 140px;
      background: var(--bg-deep);
      border-radius: var(--radius-sm);
      position: relative;
      overflow: hidden;
      margin-bottom: 12px;
    }
    .threat-bar-fill {
      position: absolute;
      bottom: 0; left: 0; right: 0;
      border-radius: var(--radius-sm);
      transition: height 1s ease-out;
      display: flex;
      align-items: center;
      justify-content: center;
    }
    .threat-bar-fill.high { background: linear-gradient(to top, rgba(239,68,68,0.8), rgba(239,68,68,0.3)); }
    .threat-bar-fill.medium { background: linear-gradient(to top, rgba(245,158,11,0.8), rgba(245,158,11,0.3)); }
    .threat-bar-fill.low { background: linear-gradient(to top, rgba(6,182,212,0.8), rgba(6,182,212,0.3)); }
    .threat-bar-count {
      font-family: 'JetBrains Mono', monospace;
      font-size: 1.75rem;
      font-weight: 700;
      color: var(--text-primary);
      text-shadow: 0 2px 8px rgba(0,0,0,0.5);
    }
    .threat-bar-label {
      font-size: 0.8rem;
      color: var(--text-secondary);
      font-weight: 500;
    }

    /* Table */
    .table-wrap {
      overflow-x: auto;
      border-radius: var(--radius-lg);
      border: 1px solid var(--border);
    }
    .threats-table {
      width: 100%;
      border-collapse: collapse;
      font-size: 0.875rem;
    }
    .threats-table thead th {
      background: var(--bg-surface);
      padding: 14px 16px;
      text-align: left;
      font-weight: 600;
      color: var(--text-secondary);
      font-size: 0.75rem;
      text-transform: uppercase;
      letter-spacing: 0.5px;
      border-bottom: 1px solid var(--border);
    }
    .threats-table tbody td {
      padding: 12px 16px;
      border-bottom: 1px solid var(--border);
      color: var(--text-primary);
    }
    .threats-table tbody tr:hover td {
      background: var(--bg-card-hover);
    }
    .threats-table tbody tr:last-child td { border-bottom: none; }
    .td-user {
      display: flex;
      align-items: center;
      gap: 10px;
      font-weight: 500;
    }
    .user-icon {
      width: 32px; height: 32px;
      border-radius: 50%;
      background: var(--accent-glow);
      color: var(--accent);
      display: inline-flex;
      align-items: center;
      justify-content: center;
      font-family: 'JetBrains Mono', monospace;
      font-size: 0.8rem;
      font-weight: 700;
      text-transform: uppercase;
    }
    .score-badge {
      display: inline-block;
      padding: 4px 12px;
      border-radius: 100px;
      font-family: 'JetBrains Mono', monospace;
      font-size: 0.8rem;
      font-weight: 600;
    }
    .score-badge.high { background: rgba(239,68,68,0.15); color: #f87171; }
    .score-badge.medium { background: rgba(245,158,11,0.15); color: #fbbf24; }
    .score-badge.low { background: rgba(6,182,212,0.15); color: var(--accent-light); }
    .type-tag {
      display: inline-block;
      padding: 3px 10px;
      border-radius: 6px;
      font-size: 0.75rem;
      font-weight: 500;
      background: var(--bg-deep);
      color: var(--text-secondary);
      border: 1px solid var(--border);
    }
    .mono { font-family: 'JetBrains Mono', monospace; }

    /* Bot Type Distribution */
    .type-distribution {
      background: var(--bg-card);
      border-radius: var(--radius-lg);
      padding: 24px;
      border: 1px solid var(--border);
    }
    .type-row {
      display: grid;
      grid-template-columns: 140px 1fr 60px;
      align-items: center;
      gap: 12px;
      padding: 10px 0;
      border-bottom: 1px solid var(--border);
    }
    .type-row:last-child { border-bottom: none; }
    .type-label {
      font-size: 0.8rem;
      font-weight: 500;
      color: var(--text-primary);
    }
    .type-track {
      height: 28px;
      background: var(--bg-deep);
      border-radius: var(--radius-sm);
      overflow: hidden;
      position: relative;
    }
    .type-fill {
      height: 100%;
      border-radius: var(--radius-sm);
      background: linear-gradient(90deg, var(--accent-dark), var(--accent));
      display: flex;
      align-items: center;
      justify-content: flex-end;
      padding-right: 10px;
      font-family: 'JetBrains Mono', monospace;
      font-size: 0.75rem;
      font-weight: 600;
      color: var(--text-primary);
      min-width: 36px;
      transition: width 1s ease-out;
    }
    .type-pct {
      font-size: 0.8rem;
      color: var(--text-secondary);
      text-align: right;
    }

    /* Recommendations */
    .rec-list {
      list-style: none;
      display: flex;
      flex-direction: column;
      gap: 12px;
    }
    .rec-list li {
      display: flex;
      gap: 14px;
      padding: 18px 20px;
      border-radius: var(--radius-sm);
      border-left: 3px solid;
      background: var(--bg-card);
    }
    .rec-list li.rec-high { border-left-color: var(--danger); }
    .rec-list li.rec-medium { border-left-color: var(--warning); }
    .rec-list li.rec-low { border-left-color: var(--success); }
    .rec-icon { font-size: 1.25rem; flex-shrink: 0; margin-top: 2px; }
    .rec-list li > div { font-size: 0.9rem; color: var(--text-secondary); }
    .rec-list li > div strong { color: var(--text-primary); font-weight: 600; }

    /* Footer */
    .footer {
      padding: 40px 0;
      text-align: center;
      background: var(--bg-surface);
      border-top: 1px solid var(--border);
    }
    .footer-brand {
      font-weight: 700;
      color: var(--accent);
      letter-spacing: -0.01em;
      margin-bottom: 8px;
    }
    .footer-meta {
      font-size: 0.8rem;
      color: var(--text-muted);
      font-family: 'JetBrains Mono', monospace;
    }
    .footer-valid {
      display: inline-block;
      margin-top: 12px;
      padding: 6px 16px;
      border-radius: 100px;
      font-size: 0.75rem;
      color: var(--success);
      background: rgba(16, 185, 129, 0.1);
      border: 1px solid rgba(16, 185, 129, 0.2);
    }

    /* Responsive */
    @media (max-width: 768px) {
      .header-grid { grid-template-columns: 1fr; }
      .header-score { width: 100%; }
      .stats-grid { grid-template-columns: repeat(2, 1fr); }
      .threat-bars-wrap { flex-direction: column; }
      .header h1 { font-size: 1.6rem; }
      .cat-grid { grid-template-columns: repeat(2, 1fr); }
      .type-row { grid-template-columns: 100px 1fr 50px; }
    }
  </style>
</head>
<body>

<!-- Header -->
<header class="header">
  <div class="container header-grid">
    <div>
      <div class="header-badge"><span class="dot"></span> Vigilante Bot Report</div>
      <h1>Follower Analysis Report</h1>
      <div class="target">@${report.customer}</div>
      <div class="date">Generated on ${generatedAt} &middot; Report ID: ${report.scan_id}</div>
    </div>
    <div class="header-score">
      <div class="score-label">Bot Rate</div>
      <div class="score-value ${botRate > 30 ? "danger" : botRate > 15 ? "warning" : "success"}">${botRate.toFixed(1)}%</div>
      <div class="score-desc">$${botRate > 30 ? "Critical Risk" : botRate > 15 ? "Moderate Risk" : "Low Risk"}</div>
    </div>
  </div>
</header>

<!-- Stats Overview -->
<section class="section">
  <div class="container">
    <div class="section-title">
      <span class="icon">\u{1F4CA}</span>
      Scan Overview
    </div>
    <div class="stats-grid">
      <div class="stat-card">
        <div class="stat-label">Total Scanned</div>
        <div class="stat-value mono accent">${s.total_scanned.toLocaleString()}</div>
        <div class="stat-bar"><div class="stat-bar-fill" style="width:100%"></div></div>
      </div>
      <div class="stat-card">
        <div class="stat-label">Bot Rate</div>
        <div class="stat-value mono danger">${s.fake_pct.toFixed(1)}%</div>
        <div class="stat-bar"><div class="stat-bar-fill" style="width:${Math.min(100, s.fake_pct)}%; background:var(--danger)"></div></div>
      </div>
      <div class="stat-card">
        <div class="stat-label">Inactive %</div>
        <div class="stat-value mono warning">${s.inactive_pct.toFixed(1)}%</div>
        <div class="stat-bar"><div class="stat-bar-fill" style="width:${Math.min(100, s.inactive_pct)}%; background:var(--warning)"></div></div>
      </div>
      <div class="stat-card">
        <div class="stat-label">Active %</div>
        <div class="stat-value mono success">${s.active_pct.toFixed(1)}%</div>
        <div class="stat-bar"><div class="stat-bar-fill" style="width:${Math.min(100, s.active_pct)}%; background:var(--success)"></div></div>
      </div>
    </div>

    <div class="cat-grid" style="margin-top:16px;">
      <div class="cat-card danger">
        <div class="cat-count mono">${s.fake_count.toLocaleString()}</div>
        <div class="cat-label">Fake Accounts</div>
        <div class="cat-pct">${s.fake_pct.toFixed(1)}%</div>
      </div>
      <div class="cat-card warning">
        <div class="cat-count mono">${s.inactive_count.toLocaleString()}</div>
        <div class="cat-label">Inactive Humans</div>
        <div class="cat-pct">${s.inactive_pct.toFixed(1)}%</div>
      </div>
      <div class="cat-card success">
        <div class="cat-count mono">${s.active_count.toLocaleString()}</div>
        <div class="cat-label">Active Humans</div>
        <div class="cat-pct">${s.active_pct.toFixed(1)}%</div>
      </div>
      <div class="cat-card accent">
        <div class="cat-count mono">${s.total_reach.toLocaleString()}</div>
        <div class="cat-label">Total Bot Reach</div>
        <div class="cat-pct">followers</div>
      </div>
    </div>
  </div>
</section>

<!-- Threat Level Distribution -->
<section class="section">
  <div class="container">
    <div class="section-title">
      <span class="icon">\u{1F525}</span>
      Threat Level Distribution
    </div>
    <div class="threat-bars-wrap">
      <div class="threat-bar-card">
        <div class="threat-bar-track">
          <div class="threat-bar-fill high" style="height:${highH}%"><span class="threat-bar-count">${s.threat_levels.high}</span></div>
        </div>
        <div class="threat-bar-label">High Threat</div>
      </div>
      <div class="threat-bar-card">
        <div class="threat-bar-track">
          <div class="threat-bar-fill medium" style="height:${medH}%"><span class="threat-bar-count">${s.threat_levels.medium}</span></div>
        </div>
        <div class="threat-bar-label">Medium Threat</div>
      </div>
      <div class="threat-bar-card">
        <div class="threat-bar-track">
          <div class="threat-bar-fill low" style="height:${lowH}%"><span class="threat-bar-count">${s.threat_levels.low}</span></div>
        </div>
        <div class="threat-bar-label">Low Threat</div>
      </div>
    </div>
  </div>
</section>

<!-- Top 20 Threats -->
<section class="section">
  <div class="container">
    <div class="section-title">
      <span class="icon">\u{1F3AF}</span>
      Top 20 Threat Bots
    </div>
    <div class="table-wrap">
      <table class="threats-table">
        <thead>
          <tr>
            <th>#</th>
            <th>Username</th>
            <th>Bot Score</th>
            <th>Type</th>
            <th>Followers</th>
            <th>Following</th>
          </tr>
        </thead>
        <tbody>
${threatRows}
        </tbody>
      </table>
    </div>
  </div>
</section>

<!-- Bot Type Distribution -->
<section class="section">
  <div class="container">
    <div class="section-title">
      <span class="icon">\u{1F916}</span>
      Bot Type Distribution
    </div>
    <div class="type-distribution">
${typeBars}
    </div>
  </div>
</section>

<!-- Recommendations -->
<section class="section">
  <div class="container">
    <div class="section-title">
      <span class="icon">\u{1F4A1}</span>
      Recommendations
    </div>
    <ul class="rec-list">
${recs}
    </ul>
  </div>
</section>

<!-- Footer -->
<footer class="footer">
  <div class="container">
    <div class="footer-brand">Vigilante Bot Detector</div>
    <div class="footer-meta">
      Engine v${report.metadata.version} &middot; ${report.metadata.fields_extracted} fields extracted &middot; Scan duration: ${s.scan_duration}s &middot; ${s.scan_speed}
    </div>
    <div class="footer-valid">Categories sum: ${s.percentage_sum.toFixed(1)}% \u2713</div>
  </div>
</footer>

</body>
</html>`;
