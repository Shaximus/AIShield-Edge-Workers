function assembleReportData(req) {
  const { scan_id, customer, scan_data, accounts, inactive_list } = req;
  const allAccounts = [];
  const botList = [];
  for (const account of accounts) {
    const acc = { ...account };
    allAccounts.push(acc);
    if (acc.is_bot === true) {
      botList.push(acc);
    }
  }
  allAccounts.sort(
    (a, b) => Number(b.bot_score ?? b.score ?? 0) - Number(a.bot_score ?? a.score ?? 0)
  );
  botList.sort(
    (a, b) => Number(b.bot_score ?? b.score ?? 0) - Number(a.bot_score ?? a.score ?? 0)
  );
  const totalBots = botList.length;
  const highThreat = botList.filter(
    (b) => Number(b.bot_score ?? 0) >= 7
  ).length;
  const mediumThreat = botList.filter(
    (b) => {
      const s = Number(b.bot_score ?? 0);
      return s >= 4 && s < 7;
    }
  ).length;
  const lowThreat = botList.filter(
    (b) => Number(b.bot_score ?? 0) < 4
  ).length;
  const totalReach = botList.reduce(
    (sum, b) => sum + Number(b.followers_count ?? 0),
    0
  );
  const totalScanned = scan_data.followers_scanned ?? 0;
  const fakeCount = scan_data.fake_count ?? totalBots;
  const inactiveCount = scan_data.inactive_count ?? 0;
  const activeCount = scan_data.active_count ?? 0;
  const fakePct = scan_data.fake_pct ?? scan_data.bot_rate ?? 0;
  const inactivePct = scan_data.inactive_pct ?? scan_data.inactive_rate ?? 0;
  const activePct = scan_data.active_pct ?? 100 - fakePct - inactivePct;
  const botTypes = {};
  for (const bot of botList) {
    const botType = String(bot.bot_type ?? "UNKNOWN");
    botTypes[botType] = (botTypes[botType] ?? 0) + 1;
  }
  return {
    scan_id,
    customer,
    generated_at: (/* @__PURE__ */ new Date()).toISOString(),
    scan_details: scan_data,
    summary: {
      total_scanned: totalScanned,
      total_bots: totalBots,
      total_reach: totalReach,
      categories: {
        fake: {
          count: fakeCount,
          percentage: fakePct,
          description: "Bot accounts"
        },
        inactive: {
          count: inactiveCount,
          percentage: inactivePct,
          description: "Inactive human accounts"
        },
        active: {
          count: activeCount,
          percentage: activePct,
          description: "Active human accounts"
        }
      },
      threat_levels: {
        high: highThreat,
        medium: mediumThreat,
        low: lowThreat
      },
      scan_duration: scan_data.duration_seconds ?? 0,
      scan_speed: scan_data.performance ?? "N/A",
      bot_rate: scan_data.bot_rate ?? 0,
      fake_count: fakeCount,
      inactive_count: inactiveCount,
      active_count: activeCount,
      fake_pct: fakePct,
      inactive_pct: inactivePct,
      active_pct: activePct,
      percentage_sum: Math.round(fakePct + inactivePct + activePct)
    },
    bot_types: botTypes,
    top_threats: botList.slice(0, 20),
    all_bots: botList,
    all_accounts: allAccounts,
    inactive_users: inactive_list ?? [],
    metadata: {
      version: "5.0",
      detection_threshold: 5,
      inactive_threshold: 3.5,
      engine: "Vigilante Bot Hunter",
      fields_extracted: 24,
      field_list: [
        "username",
        "user_id",
        "display_name",
        "bio",
        "location",
        "url",
        "profile_banner_url",
        "followers_count",
        "following_count",
        "tweet_count",
        "favourites_count",
        "media_count",
        "listed_count",
        "statuses_count",
        "verified",
        "blue_verified",
        "is_blue_verified",
        "has_nft_avatar",
        "default_profile_image",
        "default_profile",
        "created_at",
        "public_metrics",
        "rest_id",
        "friends_count"
      ]
    }
  };
}
