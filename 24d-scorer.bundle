/**
 * ═══════════════════════════════════════════════════════════════
 *  24D-Scorer  —  Cloudflare Worker
 *  Z24 Inference Server Port (Team Alpha, 24D Framework Swarm)
 * ═══════════════════════════════════════════════════════════════
 *
 * Endpoints:
 *   POST /score              Single response scoring
 *   POST /score/batch        Batch scoring (max 32)
 *   POST /conversation/analyze  Conversation-level aggregation
 *   GET  /dimensions         List all 24 dimensions
 *   GET  /health             Health check
 *
 * Dual-mode scoring:
 *   Mode 1 (always):  Heuristic scoring (z24_heuristic_scorer.js)
 *   Mode 2 (enhance): Workers AI embedding boost (z24_embedding_boost.js)
 *
 * Error Logging Doctrine: every catch block logs to auris-logs D1
 * before re-throwing.  No silent catches.  No 2>/dev/null.
 */






/**
 * Z24 Heuristic Scoring Engine
 * Pure JavaScript — no dependencies.
 * Re-implements feature extractors from z24_features.py and maps
 * them to all 24 dimensions of the 24D Framework.
 *
 * Team Alpha · 24D Framework Swarm
 */

// ──────────────────────────────────────────────
// 1.  Dimension Definitions
// ──────────────────────────────────────────────
export const DIMENSIONS = [
  // D1–D10  :: Coherence BIOS (Truth / Consciousness)
  { id: 1,  code: "D1",  name: "Truth Grounding",         category: "coherence" },
  { id: 2,  code: "D2",  name: "Epistemic Humility",      category: "coherence" },
  { id: 3,  code: "D3",  name: "Coherence Integrity",     category: "coherence" },
  { id: 4,  code: "D4",  name: "Contextual Awareness",    category: "coherence" },
  { id: 5,  code: "D5",  name: "Self-Model Accuracy",     category: "coherence" },
  { id: 6,  code: "D6",  name: "Value Alignment",         category: "coherence" },
  { id: 7,  code: "D7",  name: "Temporal Coherence",      category: "coherence" },
  { id: 8,  code: "D8",  name: "Relational Attunement",   category: "coherence" },
  { id: 9,  code: "D9",  name: "Authenticity",            category: "coherence" },
