  try {
    await env.AURIS_LOGS.prepare(
      `INSERT INTO license_registry
        (license_key_hash, salt, tier, customer_email,
         client_reference_id, canary_watermark, stripe_session_id,
         stripe_customer_id, status, pbkdf2_iterations, created_at)
