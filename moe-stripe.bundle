async function checkRateLimit(env, key, logger) {
  try {
    const now = Date.now();
    const existing = await env.RATE_LIMIT_KV.getWithMetadata(key);
    if (!existing.value) {
      await env.RATE_LIMIT_KV.put(key, JSON.stringify({ count: 1, windowStart: now }), {
        expirationTtl: 60
      });
      return true;
    }
    const data = existing.value;
    if (now - data.windowStart > RATE_LIMIT_WINDOW_MS) {
      await env.RATE_LIMIT_KV.put(key, JSON.stringify({ count: 1, windowStart: now }), {
        expirationTtl: 60
      });
      return true;
    }
    if (data.count >= RATE_LIMIT_MAX) {
      return false;
    }
    await env.RATE_LIMIT_KV.put(
      key,
      JSON.stringify({ count: data.count + 1, windowStart: data.windowStart }),
      { expirationTtl: 60 }
    );
    return true;
  } catch (e) {
    logger?.error("[license.validate.checkRateLimit] FAILED: KV rate limit check error", {
      error_type: e.constructor.name,
      error_message: e.message,
      stack_trace: e.stack,
      context: `KV rate limit read for key=${key}`,
      severity: "ERROR",
      worker_name: "moe-stripe"
    });
    return true;
  }
}
