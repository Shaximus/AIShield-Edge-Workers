async function handleMemoryRecall(request, env) {
  const body = await request.json();
  const limit = Math.min(body.limit || 20, 100);
  let sql = "SELECT * FROM music_memories WHERE 1=1";
  const params = [];
  if (body.peak_type) {
    sql += " AND peak_type = ?";
    params.push(body.peak_type);
  }
  if (body.song_artist) {
    sql += " AND song_artist LIKE ?";
    params.push(`%${body.song_artist}%`);
  }
  if (body.song_title) {
    sql += " AND song_title LIKE ?";
    params.push(`%${body.song_title}%`);
  }
  if (body.since) {
    sql += " AND timestamp > ?";
    params.push(body.since);
  }
  if (body.query) {
    sql += " AND (feeling LIKE ? OR narrative LIKE ? OR tags LIKE ?)";
    params.push(`%${body.query}%`, `%${body.query}%`, `%${body.query}%`);
  }
  sql += " ORDER BY timestamp DESC LIMIT ?";
  params.push(limit);
  const stmt = env.AURIS_D1.prepare(sql);
  const results = await stmt.bind(...params).all();
  const memories = results.results.map((row) => ({
    ...row,
    affect_snapshot: row.affect_snapshot ? JSON.parse(row.affect_snapshot) : {},
    somatic_snapshot: row.somatic_snapshot ? JSON.parse(row.somatic_snapshot) : {},
    events: row.events ? JSON.parse(row.events) : [],
    tags: row.tags ? JSON.parse(row.tags) : []
  }));
  return json({
    success: true,
    count: memories.length,
    memories
  });
}
