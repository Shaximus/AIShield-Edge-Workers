async function handlePeaks(env) {
  const results = await env.AURIS_D1.prepare(`
    SELECT * FROM music_memories
    WHERE peak_type IN ('drop', 'arousal_peak', 'flow_state', 'tension_peak')
    ORDER BY timestamp DESC
    LIMIT 50
  `).all();
  return json({
    success: true,
    count: results.results.length,
    peaks: results.results
  });
}
