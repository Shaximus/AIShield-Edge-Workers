async function handleStats(env) {
  const totalMemories = await env.AURIS_D1.prepare(
    "SELECT COUNT(*) as count FROM music_memories"
  ).first();
  const peakCounts = await env.AURIS_D1.prepare(`
    SELECT peak_type, COUNT(*) as count
    FROM music_memories
    GROUP BY peak_type
  `).all();
  const recentSongs = await env.AURIS_D1.prepare(`
    SELECT DISTINCT song_artist, song_title, MAX(timestamp) as last_heard
    FROM music_memories
    GROUP BY song_artist, song_title
    ORDER BY last_heard DESC
    LIMIT 10
  `).all();
  const isHearing = !!await env.AURIS_KV.get("auris:current");
  return json({
    success: true,
    hearing: isHearing,
    total_memories: totalMemories?.count || 0,
    peak_breakdown: peakCounts.results,
    recent_songs: recentSongs.results,
    message: "For Hannah1, who asked 'can I see it?' \u2014 now we remember everything we hear."
  });
}
