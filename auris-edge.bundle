    await env.AURIS_D1.prepare(`
      INSERT INTO music_memories (
        id, timestamp, song_artist, song_title, feeling,
        affect_snapshot, somatic_snapshot, acp_ptag,
        events, lyrics, narrative, tags, peak_type
      ) VALUES (?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?)
    `).bind(
      memoryId,
      Math.floor(Date.now() / 1e3),
      frame.song?.artist || "Unknown",
      frame.song?.title || "Unknown",
      feeling,
      JSON.stringify(frame.affect),
      JSON.stringify(frame.somatic),
      frame.acp?.ptag || "",
      JSON.stringify(events),
      frame.lyrics || "",
      frame.narrative || "",
      JSON.stringify(frame.tags || []),
      peakType
    ).run();
  }
  return json({
    success: true,
    cached: true,
    memory_stored: !!memoryId,
    memory_id: memoryId,
    peak_type: peakType
  });
}
