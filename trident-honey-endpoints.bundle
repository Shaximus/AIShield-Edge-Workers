async function getHoneyStats(db) {
  const fn = "getHoneyStats";
  log("INFO", fn, "entry", "Aggregating honey trigger statistics");
  try {
    const totalStmt = db.prepare("SELECT COUNT(*) AS cnt FROM honey_logs");
    const totalResult = await totalStmt.first();
    const totalTriggers = totalResult?.cnt ?? 0;
    const uniqueStmt = db.prepare("SELECT COUNT(DISTINCT source_ip) AS cnt FROM honey_logs");
    const uniqueResult = await uniqueStmt.first();
    const uniqueAttackers = uniqueResult?.cnt ?? 0;
    const pathStmt = db.prepare(
      "SELECT path, COUNT(*) AS hits FROM honey_logs GROUP BY path ORDER BY hits DESC"
    );
    const pathResults = await pathStmt.all();
    const endpointHits = {};
    if (pathResults.results) {
      for (const row of pathResults.results) {
        endpointHits[row.path] = row.hits;
      }
    }
    const topStmt = db.prepare(
      "SELECT source_ip AS ip, COUNT(*) AS hits FROM honey_logs GROUP BY source_ip ORDER BY hits DESC LIMIT 10"
    );
    const topResults = await topStmt.all();
    const topAttackers = topResults.results ?? [];
    const lockStmt = db.prepare(
      "SELECT COUNT(*) AS cnt FROM honey_logs WHERE severity = 'FULL_LOCKDOWN'"
    );
    const lockResult = await lockStmt.first();
    const fullLockdowns = lockResult?.cnt ?? 0;
    const stats = {
      totalTriggers,
      uniqueAttackers,
      endpointHits,
      topAttackers,
      fullLockdowns
    };
    log("INFO", fn, "exit", "Stats aggregated", void 0, { totalTriggers, uniqueAttackers });
    return stats;
  } catch (err) {
    const msg = err instanceof Error ? err.message : String(err);
    log("ERROR", fn, "branch", `Stats aggregation error: ${msg}`);
    throw err;
  }
}
