function getClientIP(request) {
  const fn = "getClientIP";
  log("INFO", fn, "entry", "Extracting client IP");
  const cf = request.headers.get("CF-Connecting-IP");
  if (cf) {
    log("INFO", fn, "exit", `CF-Connecting-IP: ${cf}`);
    return cf;
  }
  const xff = request.headers.get("X-Forwarded-For");
  if (xff) {
    const first = xff.split(",")[0]?.trim();
    if (first) {
      log("INFO", fn, "exit", `X-Forwarded-For first: ${first}`);
      return first;
    }
  }
  const xri = request.headers.get("X-Real-IP");
  if (xri) {
    log("INFO", fn, "exit", `X-Real-IP: ${xri}`);
    return xri;
  }
  log("WARN", fn, "exit", "No IP header found; returning 0.0.0.0");
  return "0.0.0.0";
}
