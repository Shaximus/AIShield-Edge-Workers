async function escalateCanaryTrigger(trigger, env) {
  log4.info("escalateCanaryTrigger:entry", { canaryId: trigger.canaryId, sourceIp: trigger.sourceIp });
  try {
    const kvKey = `poison:canary:${trigger.canaryId}`;
    const existing = await env.SESSION_META.get(kvKey);
    const canaryData = existing ? JSON.parse(existing) : {};
    canaryData.triggeredAt = trigger.detectedAt;
    canaryData.triggerSourceIp = trigger.sourceIp;
    canaryData.triggerContext = trigger.context;
    canaryData.triggerCount = (canaryData.triggerCount || 0) + 1;
    await env.SESSION_META.put(kvKey, JSON.stringify(canaryData));
    log4.error("escalateCanaryTrigger:canary_marked_triggered", { canaryId: trigger.canaryId, triggerCount: canaryData.triggerCount });
  } catch (e) {
    log4.error("escalateCanaryTrigger:kv_write_failed", { canaryId: trigger.canaryId, error: String(e) });
  }
  try {
    const stmt = env.AURIS_LOGS.prepare(
      "INSERT INTO alerts (severity, source_ip, canary_id, context, detected_at, message) VALUES (?, ?, ?, ?, ?, ?)"
    ).bind(
      trigger.severity,
      trigger.sourceIp,
      trigger.canaryId,
      trigger.context,
      trigger.detectedAt,
      `CANARY TRIGGERED: ${trigger.canaryId} used from ${trigger.sourceIp} in ${trigger.context}`
    );
    await stmt.run();
    log4.error("escalateCanaryTrigger:alert_written_d1", { canaryId: trigger.canaryId });
  } catch (e) {
    log4.error("escalateCanaryTrigger:d1_write_failed", { canaryId: trigger.canaryId, error: String(e) });
  }
  try {
    const wasteKey = `poison:waste:${trigger.sourceIp}`;
    const wasteRaw = await env.SESSION_META.get(wasteKey);
    const waste = wasteRaw ? JSON.parse(wasteRaw) : emptyWaste();
    waste.canaryCredentialsUsed = (waste.canaryCredentialsUsed || 0) + 1;
    waste.lastUpdated = Date.now();
    await env.SESSION_META.put(wasteKey, JSON.stringify(waste));
  } catch (e) {
    log4.error("escalateCanaryTrigger:waste_update_failed", { canaryId: trigger.canaryId, error: String(e) });
  }
  log4.error("escalateCanaryTrigger:FULL_LOCKDOWN_ALERT", {
    canaryId: trigger.canaryId,
    sourceIp: trigger.sourceIp,
    severity: trigger.severity,
    action: "Recommend immediate IP block + downstream credential rotation"
  });
  log4.info("escalateCanaryTrigger:exit");
}
