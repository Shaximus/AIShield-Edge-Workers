function scanForCanaries(text, sourceIp, context) {
  log.info("scanForCanaries:entry", { sourceIp, context, textLength: text.length });
  for (const sig of CANARY_SIGNATURES) {
    if (text.includes(sig)) {
      log.warn("scanForCanaries:canary_detected", { sourceIp, context, signature: sig });
      const idMatch = text.match(/cnry_[a-f0-9]{8}_[a-f0-9]{4}_[a-f0-9]{4}_[a-f0-9]{4}_[a-f0-9]{12}/);
      const canaryId = idMatch ? idMatch[0] : "unknown";
      const trigger = {
        canaryId,
        detectedAt: Date.now(),
        sourceIp,
        context,
        severity: "CRITICAL"
      };
      log.error("scanForCanaries:CRITICAL_CANARY_TRIGGER", { trigger });
      log.info("scanForCanaries:exit_triggered", { canaryId, sourceIp });
      return trigger;
    }
  }
  const b64Words = text.match(/[A-Za-z0-9+/=]{20,}/g) || [];
  for (const word of b64Words) {
    try {
      const decoded = atob(word);
      if (decoded.includes("cnry_") || decoded.includes("trident")) {
        log.warn("scanForCanaries:watermark_detected", { sourceIp, context, decoded: decoded.slice(0, 50) });
        const idMatch = decoded.match(/cnry_[a-f0-9]{8}_[a-f0-9]{4}_[a-f0-9]{4}_[a-f0-9]{4}_[a-f0-9]{12}/);
        const trigger = {
          canaryId: idMatch ? idMatch[0] : "unknown",
          detectedAt: Date.now(),
          sourceIp,
          context,
          severity: "CRITICAL"
        };
        log.error("scanForCanaries:CRITICAL_WATERMARK_TRIGGER", { trigger });
        return trigger;
      }
    } catch {
      continue;
    }
  }
  log.info("scanForCanaries:exit_clean", { sourceIp, context });
  return null;
}
