async function handleListCanaries(request, env) {
  log4.info("handleListCanaries:entry");
  try {
    const list = await env.SESSION_META.list({ prefix: "poison:canary:" });
    const canaries = [];
    for (const key of list.keys) {
      try {
        const raw = await env.SESSION_META.get(key.name);
        if (raw) {
          const data = JSON.parse(raw);
          canaries.push({ id: key.name.replace("poison:canary:", ""), ...data });
        }
      } catch (e) {
        log4.error("handleListCanaries:parse_failed", { key: key.name, error: String(e) });
      }
    }
    log4.info("handleListCanaries:exit", { count: canaries.length });
    return jsonResponse({ canaries, total: canaries.length });
  } catch (e) {
    log4.error("handleListCanaries:failed", { error: String(e) });
    return errorResponse("Failed to list canaries", 500, { reason: String(e) });
  }
}
