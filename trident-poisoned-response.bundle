    log4.info("isWhitelisted:branch_static_ip_match", { clientIp });
    return true;
  }
  if (WHITELISTED_API_KEYS.has(apiKey)) {
    log4.info("isWhitelisted:branch_static_key_match");
    return true;
  }
  try {
    const kvKey = `whitelist:ip:${clientIp}`;
    const kvValue = await env.SESSION_META.get(kvKey);
    if (kvValue) {
      log4.info("isWhitelisted:branch_kv_ip_match", { clientIp });
      return true;
