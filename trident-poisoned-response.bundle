      case "level":
        row[col] = "INFO";
        break;
      case "service":
        row[col] = `svc_${Math.random().toString(36).slice(2, 6)}`;
        break;
      case "message":
        row[col] = `Log entry ${idx} \u2014 canary:${canaryId.slice(0, 12)}`;
