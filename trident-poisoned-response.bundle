async function detectCanaryInRequest(request, env) {
  log4.info("detectCanaryInRequest:entry");
  const clientIp = request.headers.get("CF-Connecting-IP") || "unknown";
  const url = new URL(request.url);
  const urlTrigger = scanForCanaries(url.toString(), clientIp, "url");
  if (urlTrigger) {
    log4.error("detectCanaryInRequest:branch_url_trigger", { trigger: urlTrigger });
    await escalateCanaryTrigger(urlTrigger, env);
    return urlTrigger;
  }
  const headerText = Array.from(request.headers.entries()).map(([k, v]) => `${k}:${v}`).join("\n");
  const headerTrigger = scanForCanaries(headerText, clientIp, "headers");
  if (headerTrigger) {
    log4.error("detectCanaryInRequest:branch_header_trigger", { trigger: headerTrigger });
    await escalateCanaryTrigger(headerTrigger, env);
    return headerTrigger;
  }
  if (["POST", "PUT", "PATCH"].includes(request.method)) {
    try {
      const cloned = request.clone();
      const bodyText = await cloned.text();
      const bodyTrigger = scanForCanaries(bodyText, clientIp, `body:${request.method}`);
      if (bodyTrigger) {
        log4.error("detectCanaryInRequest:branch_body_trigger", { trigger: bodyTrigger });
        await escalateCanaryTrigger(bodyTrigger, env);
        return bodyTrigger;
      }
    } catch (e) {
      log4.error("detectCanaryInRequest:body_read_failed", { clientIp, error: String(e) });
    }
  }
  log4.info("detectCanaryInRequest:exit_clean", { clientIp });
  return null;
}
