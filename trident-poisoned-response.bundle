    const dims = [4096, 4096, 11008, 32e3, 128];
    shape = layerIdx % 3 === 0 ? [dims[0], dims[1]] : [dims[0], dims[2]];
  } else if (arch.includes("resnet") || arch.includes("yolo")) {
    const ch = [64, 128, 256, 512];
