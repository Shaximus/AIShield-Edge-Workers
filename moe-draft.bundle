      `INSERT INTO AURIS_LOGS (timestamp, worker, level, stage, message, payload, request_id)
       VALUES (?1, ?2, ?3, ?4, ?5, ?6, ?7)`
    );
    try {
      await this.db.batch(
        batch.map(
          (e) => stmt.bind(
            e.timestamp,
            e.worker,
            e.level,
            e.stage,
            e.message,
            e.payload ? JSON.stringify(e.payload) : null,
            e.requestId ?? null
          )
        )
      );
    } catch (firstErr) {
      try {
        await this.db.batch(
          batch.map(
            (e) => stmt.bind(
              e.timestamp,
              e.worker,
              e.level,
              e.stage,
              e.message,
              e.payload ? JSON.stringify(e.payload) : null,
              e.requestId ?? null
            )
          )
        );
      } catch (retryErr) {
        console.error("[DraftLogger] D1 flush failed after retry:", retryErr);
        for (const e of batch) {
          console.error(JSON.stringify(e));
        }
      }
    }
  }
  /**
   * Emit to Cloudflare Workers console for real-time tail.
   */
  emitConsole(entry) {
    const line = `[${entry.timestamp}] [${entry.level}] [${entry.stage}] ${entry.message}`;
    switch (entry.level) {
      case "ERROR":
        console.error(line, entry.payload ?? "");
        break;
      case "WARN":
        console.warn(line, entry.payload ?? "");
        break;
      case "DEBUG":
        console.debug(line, entry.payload ?? "");
        break;
      default:
        console.log(line, entry.payload ?? "");
    }
  }
};

