    this.emitConsole(entry);
    if (this.inMemoryBuffer.length >= this.bufferMaxSize) {
      this.flush().catch((e) => {
        console.error(`[draft.DraftLogger] FAILED: background flush error: ${e.message}`, {
          error_type: e.constructor.name,
          stack_trace: e.stack,
          context: "Background log flush to D1",
          severity: "ERROR",
          worker_name: "moe-draft"
        });
      });
    }
  }
  debug(stage, message, payload) {
    this.log("DEBUG", stage, message, payload);
  }
  info(stage, message, payload) {
    this.log("INFO", stage, message, payload);
  }
  warn(stage, message, payload) {
    this.log("WARN", stage, message, payload);
  }
  error(stage, message, payload) {
    this.log("ERROR", stage, message, payload);
  }
  /**
   * Flush all buffered entries to D1.  Retries once on failure.
   */
  async flush() {
