        await logError(env, "vigilante-api", "ERROR", `batch persistDetection: ${e.message}`, e.stack || "");
      }
      if (result.is_bot) {
        botsFound++;
      } else {
        humansFound++;
      }
      try {
        await incrementLicenseUsage(env, license);
      } catch {
        break;
      }
      license.used_today += 1;
    } catch (e) {
      await logError(env, "vigilante-api", "ERROR", `batch profile processing: ${e.message}`, e.stack || "");
    }
  }
  const durationSec = Math.round((Date.now() - startTime) / 1e3);
  const botRate = toProcess.length > 0 ? botsFound / toProcess.length : 0;
  try {
    await env.VIGILANTE_DB.prepare(
      `UPDATE scans SET status = ?, bots_found = ?, humans_found = ?,
       bot_rate = ?, duration_seconds = ?, completed_at = ? WHERE id = ?`
    ).bind("completed", botsFound, humansFound, botRate, durationSec, (/* @__PURE__ */ new Date()).toISOString(), scanId).run();
