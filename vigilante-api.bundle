  ).bind(
    d.id,
    d.scan_id,
    d.username,
    d.user_id ?? null,
    d.display_name ?? null,
    d.is_bot ? 1 : 0,
    d.bot_score,
    d.bot_type,
    d.threat_level,
    d.confidence,
    d.ml_probability,
    d.decision_path,
    JSON.stringify(d.evidence),
    d.profile_data,
    d.created_at
  ).run();
}
