async function handleGetScan(_request, env, corsHeaders, id) {
  const scan = await getScanById(env, id);
  if (!scan) {
    return jsonResponse({ error: "Scan not found", id }, 404, corsHeaders);
  }
  let detections = [];
  try {
    const { results } = await env.VIGILANTE_DB.prepare(
      `SELECT * FROM detections WHERE scan_id = ? ORDER BY created_at DESC`
    ).bind(id).all();
    if (results) {
      detections = results.map((row) => rowToDetection(row));
    }
  } catch (e) {
    await logError(env, "vigilante-api", "ERROR", `fetchScanDetections: ${e.message}`, e.stack || "");
  }
  return jsonResponse({
    scan,
    detections,
    summary: {
      total: scan.total_accounts,
      bots_found: scan.bots_found,
      humans_found: scan.humans_found,
      bot_rate: scan.bot_rate,
      duration_seconds: scan.duration_seconds
    }
  }, 200, corsHeaders);
}
