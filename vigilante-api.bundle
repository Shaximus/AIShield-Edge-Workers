async function handleDetect(request, env, corsHeaders) {
  let body;
  try {
    body = await request.json();
  } catch {
    return jsonResponse({ error: "Invalid JSON body" }, 400, corsHeaders);
  }
  if (!body.profile || typeof body.profile !== "object") {
    return jsonResponse({ error: 'Missing "profile" field in request body' }, 400, corsHeaders);
  }
  const apiKey = request.headers.get("X-API-Key");
  let license;
  try {
    license = await validateLicense(env, apiKey);
  } catch (e) {
    const msg = e.message;
    if (msg.includes("quota exceeded")) {
      return jsonResponse({ error: msg, code: "QUOTA_EXCEEDED" }, 429, corsHeaders);
    }
    return jsonResponse({ error: msg, code: "UNAUTHORIZED" }, 401, corsHeaders);
  }
  const features = extractFeatures(body.profile);
  const result = runHeuristicDetection(body.profile, features);
  try {
    await persistDetection(env, result);
  } catch (e) {
    await logError(env, "vigilante-api", "ERROR", `persistDetection: ${e.message}`, e.stack || "");
    return jsonResponse({ error: "Failed to persist detection result" }, 500, corsHeaders);
  }
  try {
    await incrementLicenseUsage(env, license);
  } catch (e) {
    await logError(env, "vigilante-api", "WARN", `incrementLicenseUsage: ${e.message}`, e.stack || "");
  }
  return jsonResponse(result, 200, corsHeaders);
}
