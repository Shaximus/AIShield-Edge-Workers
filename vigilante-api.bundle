  const scan = {
    id: scanId,
    customer: license.customer || apiKey || "anonymous",
    status: "running",
    total_accounts: toProcess.length,
    bots_found: 0,
    humans_found: 0,
    bot_rate: 0,
    inactive_count: 0,
    duration_seconds: 0,
    report_html_path: null,
    report_json_path: null,
