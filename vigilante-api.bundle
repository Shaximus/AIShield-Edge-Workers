    return jsonResponse({ error: "Failed to create scan record" }, 500, corsHeaders);
  }
  let botsFound = 0;
  let humansFound = 0;
  const startTime = Date.now();
  for (const profile of toProcess) {
    try {
      const features = extractFeatures(profile);
      const result = runHeuristicDetection(profile, features, scanId);
      try {
        await persistDetection(env, result);
