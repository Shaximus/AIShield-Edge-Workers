    throw new Error("Missing X-API-Key header");
  }
  const raw = await env.LICENSES.get(apiKey);
  if (!raw) {
    throw new Error(`Invalid API key: ${apiKey.substring(0, 8)}\u2026`);
  }
  let license;
  try {
    license = JSON.parse(raw);
