async function handleGetScanReport(request, env, corsHeaders, id) {
  const scan = await getScanById(env, id);
  if (!scan) {
    return jsonResponse({ error: "Scan not found", id }, 404, corsHeaders);
  }
  const acceptHeader = request.headers.get("Accept") || "";
  const wantJson = acceptHeader.includes("application/json");
  const r2Key = wantJson ? scan.report_json_path || `reports/${id}.json` : scan.report_html_path || `reports/${id}.html`;
  try {
    const object = await env.VIGILANTE_REPORTS.get(r2Key);
    if (!object) {
      const detections = [];
      try {
        const { results } = await env.VIGILANTE_DB.prepare(
          `SELECT * FROM detections WHERE scan_id = ? ORDER BY created_at DESC`
        ).bind(id).all();
        if (results) {
          for (const row of results) {
            detections.push(rowToDetection(row));
          }
        }
      } catch (e) {
        await logError(env, "vigilante-api", "ERROR", `reportDetections: ${e.message}`, e.stack || "");
      }
      if (wantJson) {
        return jsonResponse({
          scan,
          detections,
          generated_at: (/* @__PURE__ */ new Date()).toISOString()
        }, 200, corsHeaders);
      }
      const html = generateHTMLReport(scan, detections);
      return htmlResponse(html, 200, corsHeaders);
    }
    const body = await object.arrayBuffer();
    const contentType = wantJson ? "application/json" : "text/html; charset=utf-8";
    return new Response(body, {
      status: 200,
      headers: { ...corsHeaders, "Content-Type": contentType }
    });
  } catch (e) {
    await logError(env, "vigilante-api", "ERROR", `getScanReport: ${e.message}`, e.stack || "");
    return jsonResponse({ error: "Failed to retrieve report" }, 500, corsHeaders);
  }
}
